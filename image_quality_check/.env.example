# Image Quality Check (IQC) microservice environment
# Copy this file to .env and adjust values for your environment.

# Optional service auth (disabled by default for local/dev)
IQC_API_KEY=

# Callback target (Laravel endpoint without trailing /{job_id}/status)
IQC_CALLBACK_URL=http://127.0.0.1:8000/api/internal/iqc/jobs

# Callback auth: must match Laravel IQC_CALLBACK_TOKEN
IQC_CALLBACK_TOKEN=replace-with-iqc-callback-token

# Callback delivery behavior
IQC_CALLBACK_TIMEOUT_SECONDS=30
IQC_CALLBACK_MAX_RETRIES=3
IQC_CALLBACK_RETRY_DELAY_SECONDS=1.5

# Resolution thresholds
IQC_SOFT_MIN_WIDTH=1800
IQC_SOFT_MIN_HEIGHT=1200
IQC_HARD_MIN_WIDTH=1000
IQC_HARD_MIN_HEIGHT=700

# File size limit in bytes (default: 50 MB)
IQC_MAX_FILE_BYTES=52428800

# Focus and IQA thresholds
IQC_LAPLACIAN_THRESHOLD=120
IQC_BRISQUE_THRESHOLD=40
